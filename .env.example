# ============================================================
#  CRM-AI · variables de entorno
#  Copia este archivo a `.env` y completa los valores.
#  El archivo `.env` está en .gitignore — nunca se sube al repo.
# ============================================================

# ----- Supabase (proyecto crm-ai, sa-east-1) -----
# Cliente (browser): URL pública + publishable key (anon)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Servidor (Edge Functions): service_role key
# Sólo se usa dentro de Edge Functions, nunca expuesta al browser.
SUPABASE_SERVICE_ROLE_KEY=

# ----- Motor agéntico (host Python: Railway/Fly/VPS) -----
# La UI lo consume para lanzar corridas del Crew. Ver agent-engine/DEPLOY.md
VITE_ENGINE_URL=
VITE_ENGINE_KEY=

# ----- LLM providers -----
# Groq — https://console.groq.com/keys
GROQ_API_KEY=
# Modelo por defecto del CEO/Brand Managers (puede sobreescribirse por agente en BD)
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# (Opcional, fase posterior)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ----- Higgsfield (imágenes/videos) -----
# Dashboard: https://cloud.higgsfield.ai/api-keys
# Autenticación oficial: Authorization: Key {API_KEY}:{API_SECRET}
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=

# ----- Telegram bot (fase posterior, dejar vacío por ahora) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ----- Email (fase posterior) -----
RESEND_API_KEY=

# ----- Heartbeat -----
# Intervalo del cron (lo configura pg_cron, no se lee desde acá).
# Documentado aquí para referencia: cada minuto en producción, cada 5 min en dev.
HEARTBEAT_CADENCE=1m
